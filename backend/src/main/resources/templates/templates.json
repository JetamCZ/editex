{
  "templates": [
    {
      "id": "empty",
      "name": "Empty Project",
      "description": "Start from scratch with no files",
      "files": [
        {
          "path": "/files",
          "filename": "main.tex",
          "templateFile": "empty/main.tex"
        }
      ]
    },
    {
      "id": "default",
      "name": "Default Template",
      "description": "A complete LaTeX document with sections demonstrating basic features",
      "files": [
        {
          "path": "/files",
          "filename": "main.tex",
          "templateFile": "default/main.tex"
        },
        {
          "path": "/files/sections",
          "filename": "01-introduction.tex",
          "templateFile": "default/sections/01-introduction.tex"
        },
        {
          "path": "/files/sections",
          "filename": "02-examples.tex",
          "templateFile": "default/sections/02-examples.tex"
        }
      ]
    },
    {
      "id": "overleaf",
      "name": "Overleaf Template",
      "description": "A template with an example document and image",
      "files": [
        {
          "path": "/files",
          "filename": "main.tex",
          "templateFile": "overleaf/main.tex"
        },
        {
          "path": "/files",
          "filename": "frog.jpg",
          "templateFile": "overleaf/frog.jpg"
        },
        {
          "path": "/files",
          "filename": "sample.bib",
          "templateFile": "overleaf/sample.bib"
        }
      ]
    }
  ]
}
