# ===========================================
# Frontend Configuration
# ===========================================
VITE_BACKEND_URL=https://api.editex.eu
VITE_WS_URL=https://api.editex.eu/ws
BACKEND_URL=http://backend:8080/api
SECURE_COOKIE=true
COOKIE_SECRET=your-secure-cookie-secret-min-32-chars

# ===========================================
# Database Configuration (PostgreSQL)
# ===========================================
POSTGRES_USER=editex
POSTGRES_PASSWORD=your-secure-database-password
POSTGRES_DB=editex

# ===========================================
# JWT Configuration
# ===========================================
JWT_SECRET=your-secure-jwt-secret-key-min-64-chars-for-hs512
JWT_EXPIRATION=86400000

# ===========================================
# Hetzner Object Storage (S3-compatible)
# ===========================================
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET_NAME=editex-files
# Region must match your Hetzner location (e.g., fsn1-dc14, nbg1-dc3, hel1-dc2)
S3_REGION=fsn1-dc14

# ===========================================
# Email Configuration (SMTP)
# ===========================================
# For development: Use Mailtrap (https://mailtrap.io)
#   MAIL_HOST=sandbox.smtp.mailtrap.io
#   MAIL_PORT=2525
#   MAIL_PROTOCOL=smtp
#   MAIL_SSL=false
#   MAIL_STARTTLS=true
#
# For Seznam.cz (port 465 with SSL):
#   MAIL_HOST=smtp.seznam.cz
#   MAIL_PORT=465
#   MAIL_PROTOCOL=smtps    <-- Important: use smtps for SSL on port 465
#   MAIL_SSL=true
#   MAIL_STARTTLS=false
#
# For production: Use any SMTP provider (Mailgun, SendGrid, AWS SES, etc.)
#
MAIL_HOST=smtp.seznam.cz
MAIL_PORT=465
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-smtp-password
MAIL_PROTOCOL=smtps
MAIL_AUTH=true
MAIL_SSL=true
MAIL_STARTTLS=false
MAIL_FROM=your-email@example.com
# Set to true to enable detailed SMTP debug logging
MAIL_DEBUG=false

# ===========================================
# Frontend URL (for email links)
# ===========================================
FRONTEND_URL=https://editex.eu
