# ===========================================
# Frontend Configuration
# ===========================================
VITE_BACKEND_URL=https://api.editex.eu
VITE_WS_URL=wss://api.editex.eu/ws
BACKEND_URL=http://backend:8080/api
SECURE_COOKIE=true
COOKIE_SECRET=your-secure-cookie-secret-min-32-chars

# ===========================================
# Database Configuration (PostgreSQL)
# ===========================================
POSTGRES_USER=editex
POSTGRES_PASSWORD=your-secure-database-password
POSTGRES_DB=editex

# ===========================================
# JWT Configuration
# ===========================================
JWT_SECRET=your-secure-jwt-secret-key-min-64-chars-for-hs512
JWT_EXPIRATION=86400000

# ===========================================
# Hetzner Object Storage (S3-compatible)
# ===========================================
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET_NAME=editex-files
# Region must match your Hetzner location (e.g., fsn1-dc14, nbg1-dc3, hel1-dc2)
S3_REGION=fsn1-dc14
